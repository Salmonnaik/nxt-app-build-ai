{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "env": {
    "VITE_API_URL": "https://nxt-app-build-ai-production.up.railway.app/api"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}
